# ──────────────────────────────────────────────────────────────────────────────
# Ambiente — Gestão de Rebanho Bovino (Recria Individual)
# Copie este arquivo para .env e preencha os valores.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recria_bovina?schema=public"

# NextAuth
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="substitua-por-uma-chave-secreta-forte"
NEXTAUTH_URL="http://localhost:3000"

# Ambiente
NODE_ENV="development"
